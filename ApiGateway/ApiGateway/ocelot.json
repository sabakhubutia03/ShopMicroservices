{
  "Routes": [
    {
      "UpstreamPathTemplate": "/api/user/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE"],
      "DownstreamPathTemplate": "/api/user/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "userservice",
          "Port": 8080
        }
      ],
      "SwaggerKey": "userservice"
    },
    {
      "UpstreamPathTemplate": "/api/product/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE"],
      "DownstreamPathTemplate": "/api/product/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "productservice",
          "Port": 8080
        }
      ],
      "SwaggerKey": "productservice"
    },
    {
      "UpstreamPathTemplate": "/api/category/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE"],
      "DownstreamPathTemplate": "/api/category/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "productservice",
          "Port": 8080
        }
      ],
      "SwaggerKey": "productservice"
    },
    {
      "UpstreamPathTemplate": "/api/order/{everything}",
      "UpstreamHttpMethod": ["GET", "POST", "PUT", "DELETE"],
      "DownstreamPathTemplate": "/api/order/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "orderservice",
          "Port": 8080
        }
      ],
      "SwaggerKey": "orderservice"
    }
  ],
  "SwaggerEndPoints": [
    {
      "Key": "userservice",
      "Config": [
        {
          "Name": "User Service",
          "Version": "v1",
          "Url": "http://userservice:8080/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "productservice",
      "Config": [
        {
          "Name": "Product Service",
          "Version": "v1",
          "Url": "http://productservice:8080/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "orderservice",
      "Config": [
        {
          "Name": "Order Service",
          "Version": "v1",
          "Url": "http://orderservice:8080/swagger/v1/swagger.json"
        }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000"
  }
}